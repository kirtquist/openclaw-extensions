{
  "name": "bible-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Bible slash-command plugin",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/prompts && cp prompts/*.md dist/prompts/"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.5.18",
    "typescript": "^5.6.0"
  }
}
